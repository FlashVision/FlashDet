# ═══════════════════════════════════════════════════════════════
# Python
# ═══════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.cache
*.egg-info/
.eggs/
*.so

# ═══════════════════════════════════════════════════════════════
# Virtual environments
# ═══════════════════════════════════════════════════════════════
.venv/
venv/
env/
.env

# ═══════════════════════════════════════════════════════════════
# IDEs & editors
# ═══════════════════════════════════════════════════════════════
.idea/
.vscode/
.cursor/
*.swp
*.swo
.DS_Store
Thumbs.db

# ═══════════════════════════════════════════════════════════════
# Testing & linting
# ═══════════════════════════════════════════════════════════════
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# ═══════════════════════════════════════════════════════════════
# Build artifacts
# ═══════════════════════════════════════════════════════════════
dist/
build/
*.spec

# ═══════════════════════════════════════════════════════════════
# Training outputs (regenerated by training)
# ═══════════════════════════════════════════════════════════════
workspace/

# ═══════════════════════════════════════════════════════════════
# Model weights & exports (large — share via Releases / LFS)
# ═══════════════════════════════════════════════════════════════
*.pth
*.onnx
*.onnx.data
*.pt
*.ckpt
*.bin
*.safetensors
pretrained/
exported_models*/
quantized_models/

# ═══════════════════════════════════════════════════════════════
# Datasets (large — only data/demo/ is tracked for quick tests)
# ═══════════════════════════════════════════════════════════════
data/*
!data/demo/

# ═══════════════════════════════════════════════════════════════
# Logs
# ═══════════════════════════════════════════════════════════════
*.log
nohup.out

# ═══════════════════════════════════════════════════════════════
# ML experiment tracking
# ═══════════════════════════════════════════════════════════════
wandb/
mlruns/
runs/
lightning_logs/

# ═══════════════════════════════════════════════════════════════
# Images (large — do not track binary images)
# ═══════════════════════════════════════════════════════════════
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.webp
*.ico
*.svg
!assets/logo.png

# ═══════════════════════════════════════════════════════════════
# Media & archives
# ═══════════════════════════════════════════════════════════════
samples/*.mp4
output/
*.zip
*.tar
*.tar.gz
*.tgz

# ═══════════════════════════════════════════════════════════════
# Results & benchmarks (regenerated)
# ═══════════════════════════════════════════════════════════════
results/

# ═══════════════════════════════════════════════════════════════
# Temp
# ═══════════════════════════════════════════════════════════════
tmp/
temp/
TEMPDATA/
